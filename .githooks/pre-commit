#!/usr/bin/env bash
# Hook versionné : activé via `scripts/setup-git-hooks.sh` (git config core.hooksPath .githooks).
# Bloque le commit si Semgrep trouve un problème dans les fichiers stagés.
# Échappatoire volontaire : SKIP_SEMGREP=1 git commit ...
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if [ "${SKIP_SEMGREP:-0}" = "1" ]; then
  echo "SKIP_SEMGREP=1 : scan Semgrep ignoré pour ce commit."
  exit 0
fi

STAGED_FILES=()
while IFS= read -r f; do
  [ -n "$f" ] && STAGED_FILES+=("$f")
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [ "${#STAGED_FILES[@]}" -eq 0 ]; then
  exit 0
fi

echo "Semgrep (Docker) : analyse de ${#STAGED_FILES[@]} fichier(s) stagé(s)..."

if ! "$REPO_ROOT/scripts/semgrep-scan.sh" "${STAGED_FILES[@]}"; then
  echo ""
  echo "Semgrep a trouvé des problèmes bloquants. Corrige-les avant de commit."
  echo "Pour forcer le commit malgré tout : SKIP_SEMGREP=1 git commit ..."
  exit 1
fi
