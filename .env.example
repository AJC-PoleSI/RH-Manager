DATABASE_URL="file:./dev.db"
JWT_SECRET="REPLACE_WITH_SECURE_SECRET_KEY"
PORT=4000

# Origines autorisées pour le CORS (séparées par des virgules).
ALLOWED_ORIGINS="http://localhost:3000"

# Auto-inscription des membres. Désactivée par défaut : les membres (comptes
# privilégiés du jury) doivent être créés par un admin via POST /api/members.
# Mettre "true" pour réactiver POST /api/auth/register.
ALLOW_MEMBER_REGISTRATION="false"

# ── Intégration Befast ↔ RH (voir integration/README.md) ──
# Secret partagé HMAC — IDENTIQUE dans les 3 apps.
INTEGRATION_SECRET="change-me-long-random-shared-secret"
# URL de l'app BeFast (sans slash final).
BEFAST_BASE_URL="http://localhost:3001"
