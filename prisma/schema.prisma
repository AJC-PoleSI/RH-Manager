// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Candidate {
  id        String   @id @default(uuid())
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  email     String   @unique
  phone     String?
  comments  String?

  evaluations       CandidateEvaluation[]
  deliberation      Deliberation?
  evaluatorTracking EvaluatorTracking[]
  calendarEvents    CalendarEvent[]
  wishes            CandidateWish[]
  slotEnrollments   SlotEnrollment[]

  @@index([email])
  @@index([lastName, firstName])
}

model Member {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  isAdmin      Boolean  @default(false) @map("is_admin")

  evaluations       CandidateEvaluation[]
  availabilities    Availability[]
  evaluatorTracking EvaluatorTracking[]
  calendarEvents    CalendarEvent[]
  slotAssignments   SlotMemberAssignment[]
  slotRequests      SlotAvailabilityRequest[]

  @@index([email])
}

model Epreuve {
  id                    String   @id @default(uuid())
  name                  String
  tour                  Int      // 1, 2, 3
  type                  String   // oral, business game, individual, group, common
  durationMinutes       Int      @map("duration_minutes")
  roulementMinutes      Int      @default(10) @map("roulement_minutes")
  nbSalles              Int      @default(1) @map("nb_salles")
  minEvaluatorsPerSalle Int      @default(2) @map("min_evaluators_per_salle")
  dateDebut             String?  @map("date_debut")
  dateFin               String?  @map("date_fin")
  evaluationQuestions   String   @map("evaluation_questions") // Stored as JSON string
  isPoleTest            Boolean  @default(false) @map("is_pole_test")
  pole                  String?  // RH, SI, etc.
  isGroupEpreuve        Boolean  @default(false) @map("is_group_epreuve")
  groupSize             Int      @default(1) @map("group_size") // nb candidates per group (1=individual)
  isVisible             Boolean  @default(true) @map("is_visible") // Phase 4: visibility toggle

  evaluations    CandidateEvaluation[]
  calendarEvents CalendarEvent[]
  slots          EvaluationSlot[]
}

model CandidateEvaluation {
  id          String   @id @default(uuid())
  candidateId String   @map("candidate_id")
  epreuveId   String   @map("epreuve_id")
  memberId    String   @map("member_id")
  scores      String   // Stored as JSON string
  comment     String?
  createdAt   DateTime @default(now()) @map("created_at")

  candidate Candidate @relation(fields: [candidateId], references: [id])
  epreuve   Epreuve   @relation(fields: [epreuveId], references: [id])
  member    Member    @relation(fields: [memberId], references: [id])

  evaluatorTracking EvaluatorTracking[]

  @@index([candidateId])
  @@index([epreuveId])
  @@index([memberId])
}

model Deliberation {
  id             String   @id @default(uuid())
  candidateId    String   @unique @map("candidate_id")
  tour1Status    String   @default("pending") @map("tour1_status")
  tour2Status    String   @default("pending") @map("tour2_status")
  tour3Status    String   @default("pending") @map("tour3_status")
  globalComments String?  @map("global_comments")
  prosComment    String?  @map("pros_comment")
  consComment    String?  @map("cons_comment")

  candidate Candidate @relation(fields: [candidateId], references: [id])

  @@index([candidateId])
}

model EvaluatorTracking {
  id           String   @id @default(uuid())
  memberId     String   @map("member_id")
  candidateId  String   @map("candidate_id")
  evaluationId String   @unique @map("evaluation_id")
  createdAt    DateTime @default(now()) @map("created_at")

  member       Member              @relation(fields: [memberId], references: [id])
  candidate    Candidate           @relation(fields: [candidateId], references: [id])
  evaluation   CandidateEvaluation @relation(fields: [evaluationId], references: [id])

  @@index([memberId])
  @@index([candidateId])
}

model Availability {
  id        String   @id @default(uuid())
  memberId  String   @map("member_id")
  weekday   String   // Monday-Friday (Legacy/Fallback)
  date      DateTime? @map("date") // Specific date (New system)
  startTime String   @map("start_time") // HH:mm
  endTime   String   @map("end_time") // HH:mm

  member    Member @relation(fields: [memberId], references: [id])

  @@index([memberId])
}

model CalendarEvent {
  id                 String   @id @default(uuid())
  title              String
  description        String?
  day                DateTime
  startTime          String   @map("start_time")
  endTime            String   @map("end_time")
  relatedEpreuveId   String?  @map("related_epreuve_id")
  relatedMemberId    String?  @map("related_member_id")
  relatedCandidateId String?  @map("related_candidate_id")
  maxCandidates     Int      @default(1) @map("max_candidates")

  epreuve   Epreuve?   @relation(fields: [relatedEpreuveId], references: [id])
  member    Member?    @relation(fields: [relatedMemberId], references: [id])
  candidate Candidate? @relation(fields: [relatedCandidateId], references: [id])

  @@index([relatedEpreuveId])
  @@index([relatedMemberId])
  @@index([relatedCandidateId])
  @@index([day])
}

model SystemSetting {
  key   String @id
  value String
}

model CandidateWish {
  id          String @id @default(uuid())
  candidateId String @map("candidate_id")
  pole        String
  rank        Int

  candidate   Candidate @relation(fields: [candidateId], references: [id])

  @@unique([candidateId, pole])
  @@unique([candidateId, rank])
  @@index([candidateId])
}

// ============================================
// SLOT GENERATION & CANDIDATE ENROLLMENT SYSTEM
// ============================================

// A planning slot (créneau) - created by admin on the weekly grid
model EvaluationSlot {
  id                String   @id @default(uuid())
  epreuveId         String?  @map("epreuve_id") // Optional: can be a general slot
  date              DateTime
  startTime         String   @map("start_time") // HH:mm
  endTime           String   @map("end_time")   // HH:mm
  durationMinutes   Int      @default(60) @map("duration_minutes")
  room              String?  // Salle
  label             String?  // Optional label (ex: "Jury A", "Oral B2")
  maxCandidates     Int      @default(1) @map("max_candidates") // 1 for individual, up to 6 for group
  minMembers        Int      @default(1) @map("min_members") // Minimum evaluators required before visible to candidates
  simultaneousSlots Int      @default(1) @map("simultaneous_slots") // 0-5, 0 = disabled
  status            String   @default("open") // open, ready, published, full, closed, cancelled
  tour              Int      @default(1)
  createdAt         DateTime @default(now()) @map("created_at")

  epreuve       Epreuve?             @relation(fields: [epreuveId], references: [id])
  members       SlotMemberAssignment[]
  enrollments   SlotEnrollment[]
  requests      SlotAvailabilityRequest[]

  @@index([epreuveId])
  @@index([date])
  @@index([status])
}

// Member availability request on a non-opened slot
model SlotAvailabilityRequest {
  id        String   @id @default(uuid())
  slotId    String   @map("slot_id")
  memberId  String   @map("member_id")
  createdAt DateTime @default(now()) @map("created_at")

  slot   EvaluationSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  member Member         @relation(fields: [memberId], references: [id])

  @@unique([slotId, memberId])
  @@index([memberId])
}

// Which members (evaluators) are assigned to a slot
model SlotMemberAssignment {
  id       String @id @default(uuid())
  slotId   String @map("slot_id")
  memberId String @map("member_id")

  slot     EvaluationSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  member   Member         @relation(fields: [memberId], references: [id])

  @@unique([slotId, memberId])
  @@index([memberId])
}

// Candidate enrollment in a slot
model SlotEnrollment {
  id          String   @id @default(uuid())
  slotId      String   @map("slot_id")
  candidateId String   @map("candidate_id")
  status      String   @default("enrolled") // enrolled, confirmed, cancelled
  enrolledAt  DateTime @default(now()) @map("enrolled_at")

  slot        EvaluationSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  candidate   Candidate      @relation(fields: [candidateId], references: [id])

  @@unique([slotId, candidateId])
  @@index([candidateId])
  @@index([slotId])
}
